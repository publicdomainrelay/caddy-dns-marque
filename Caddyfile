# Example Caddyfile using the Marque ATProto DNS provider.
#
# Environment variables:
#   ATPROTO_HANDLE       - Your ATProto handle (e.g. user.bsky.social) or DID
#   ATPROTO_APP_PASSWORD - ATProto app password with repo write access

{
    # Uncomment for production:
    # email your-email@example.com
}

# Replace with your domain
example.com {
    tls {
        dns marque {
            handle {env.ATPROTO_HANDLE}
            app_password {env.ATPROTO_APP_PASSWORD}
        }
    }

    respond "Hello from Caddy with Marque ATProto DNS!"
}
